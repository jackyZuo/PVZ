[configuration]

entry_symbol = "tower_defense_server_init"
compatibility_minimum = "4.2"
reloadable = true

[libraries]

windows.debug.x86_64 = "res://addons/towerdefense_extension/bin/windows/libTowerDefenseServer.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://addons/towerdefense_extension/bin/windows/libTowerDefenseServer.windows.template_release.x86_64.dll"
android.debug.arm64 = "res://addons/towerdefense_extension/bin/android/libTowerDefenseServer.android.template_debug.arm64.so"
android.release.arm64 = "res://addons/towerdefense_extension/bin/android/libTowerDefenseServer.android.template_release.arm64.so"
